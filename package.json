{
  "name": "nextjs-tailwind",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bunx next dev --turbopack",
    "build": "bunx next build",
    "build:local": "bun scripts/next-cli.cjs build",
    "start": "bunx next start",
    "start:local": "bun scripts/next-cli.cjs start",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bun run typecheck && bunx eslint src next.config.ts postcss.config.mjs tailwind.config.ts eslint.config.mjs --ignore-pattern .next --ignore-pattern .next-build --ignore-pattern node_modules",
    "format": "bunx biome format --write ."
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "15.3.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "same-runtime": "^0.0.1",
    "tailwind-merge": "^3.3.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^20.17.50",
    "@types/react": "^18.3.22",
    "@types/react-dom": "^18.3.7",
    "eslint": "^9.27.0",
    "eslint-config-next": "15.1.7",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.3"
  }
}
